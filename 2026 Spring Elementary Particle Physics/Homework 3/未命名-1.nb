Cell[BoxData[{
 RowBox[{
  RowBox[{"gammaS", " ", "=", 
   RowBox[{"7.351", "*", 
    RowBox[{"10", "^", 
     RowBox[{"(", 
      RowBox[{"-", "12"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"gammaL", "=", 
   RowBox[{"1.287", "*", 
    RowBox[{"10", "^", 
     RowBox[{"(", 
      RowBox[{"-", "14"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"deltam", "=", 
   RowBox[{"3.484", "*", 
    RowBox[{"10", "^", 
     RowBox[{"(", 
      RowBox[{"-", "12"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"epsilon", "=", 
   RowBox[{"2.228", "*", 
    RowBox[{"10", "^", 
     RowBox[{"(", 
      RowBox[{"-", "3"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"phi", "=", "0.7586568615210438"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"reEps", "=", 
   RowBox[{"epsilon", "*", 
    RowBox[{"Cos", "[", "phi", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Cplus", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "gammaS"}], "*", "t"}], "]"}], "+", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"-", "gammaL"}], "*", "t"}], "]"}], "+", 
    RowBox[{"2", "*", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "0.5"}], "*", 
       RowBox[{"(", 
        RowBox[{"gammaS", "+", "gammaL"}], ")"}], "*", "t"}], "]"}], "*", 
     RowBox[{"Cos", "[", 
      RowBox[{"deltam", "*", "t"}], "]"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Cminus", "[", "t_", "]"}], ":=", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "gammaS"}], "*", "t"}], "]"}], "+", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "gammaL"}], "*", "t"}], "]"}], "-", 
     RowBox[{"2", "*", 
      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "0.5"}], "*", 
        RowBox[{"(", 
         RowBox[{"gammaS", "+", "gammaL"}], ")"}], "*", "t"}], "]"}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{"deltam", "*", "t"}], "]"}]}]}]}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"nplus", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Cplus", "[", "t", "]"}], "*", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      RowBox[{"2", "*", "reEps"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nminus", "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{"Cminus", "[", "t", "]"}], "*", 
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{"2", "*", "reEps"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"asymmetry", "[", "t_", "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"nplus", "[", "t", "]"}], "-", 
       RowBox[{"nminus", "[", "t", "]"}]}], ")"}], "/", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"nplus", "[", "t", "]"}], "+", 
       RowBox[{"nminus", "[", "t", "]"}]}], ")"}]}]}], ";"}], 
  "\n"}], "\n"}], "Input",
 CellChangeTimes->{{3.981412400239356*^9, 3.981412497126636*^9}, {
  3.981412697597293*^9, 3.981412700627213*^9}, {3.981443160296455*^9, 
  3.981443399420611*^9}, {3.981443442167139*^9, 3.9814434559527683`*^9}, {
  3.981443488555574*^9, 3.981443527913197*^9}},
 CellLabel->"In[69]:=",ExpressionUUID->"082cd429-5539-4d3f-84bc-8c90ae7b664c"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"tauS", "=", 
   RowBox[{"1", "/", "gammaS"}]}], ";"}], "\n", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"asymmetry", "[", "t", "]"}], ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", 
     RowBox[{"15", "*", "tauS"}]}], "}"}], ",", 
   RowBox[{"PlotRange", "->", "All"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<t/\[Tau]S\>\"", ",", "\"\<A(t)\>\""}], "}"}]}], ",", 
   RowBox[{
   "PlotLabel", "->", "\"\<Charge Asymmetry in Neutral Kaon Decay\>\""}], ",", 
   RowBox[{"GridLines", "->", 
    RowBox[{"{", 
     RowBox[{"None", ",", 
      RowBox[{"{", 
       RowBox[{"2", "*", "reEps"}], "}"}]}], "}"}]}], ",", 
   RowBox[{"PlotStyle", "->", "Blue"}], ",", 
   RowBox[{"Epilog", "->", 
    RowBox[{"{", 
     RowBox[{"Red", ",", "Dashed", ",", 
      RowBox[{"InfiniteLine", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", 
          RowBox[{"2", "*", "reEps"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0"}], "}"}]}], "]"}]}], "}"}]}]}], 
  "]"}]}], "Input",
