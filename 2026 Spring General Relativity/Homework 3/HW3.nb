Notebook[{

Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "1.", " ", "Define", " ", "the", " ", "integrand", " ", "functions", " ", 
    "for", " ", "f", 
    RowBox[{"(", "y", ")"}], " ", "and", " ", "g", 
    RowBox[{"(", "y", ")"}]}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"fIntegrand", "[", "t_", "]"}], ":=", 
     RowBox[{
      RowBox[{"t", "^", "4"}], "/", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"t", "^", "2"}], "+", "1"}], "]"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"gIntegrand", "[", "t_", "]"}], ":=", 
     RowBox[{
      RowBox[{"t", "^", "2"}], "*", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"t", "^", "2"}], "+", "1"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "2.", " ", "Set", " ", "the", " ", "central", " ", "dimensionless", " ", 
     "Fermi", " ", "momentum", " ", 
     RowBox[{"(", "yc", ")"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "This", " ", "parameter", " ", "controls", " ", "the", " ", "central", " ",
      "density", " ", "of", " ", "the", " ", "neutron", " ", "star"}], "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yc", "=", "1.0"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "3.", " ", "Define", " ", "the", " ", "system", " ", "of", " ", "Coupled",
      " ", "Differential", " ", "Equations"}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "We", " ", "treat", " ", "fVal", " ", "and", " ", "gVal", " ", "as", " ",
       "functions", " ", "of", " ", "x", " ", "to", " ", "avoid", " ", "re"}],
      "-", 
     RowBox[{"integrating", " ", "at", " ", "every", " ", "step"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tovEquations", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"y", "'"}], "[", "x", "]"}], "==", 
        RowBox[{
         RowBox[{"-", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"m", "[", "x", "]"}], "+", 
              RowBox[{"4", "*", "Pi", "*", 
               RowBox[{"x", "^", "3"}], "*", 
               RowBox[{"fVal", "[", "x", "]"}]}]}], ")"}], "*", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"3", "*", 
               RowBox[{"gVal", "[", "x", "]"}]}], "+", 
              RowBox[{"fVal", "[", "x", "]"}]}], ")"}]}], ")"}]}], "/", 
         RowBox[{"(", 
          RowBox[{"x", "*", 
           RowBox[{"(", 
            RowBox[{"x", "-", 
             RowBox[{"2", "*", 
              RowBox[{"m", "[", "x", "]"}]}]}], ")"}], "*", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"y", "[", "x", "]"}], "^", "4"}], "/", 
             RowBox[{"Sqrt", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"y", "[", "x", "]"}], "^", "2"}], "+", "1"}], "]"}]}],
             ")"}]}], ")"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"m", "'"}], "[", "x", "]"}], "==", 
        RowBox[{"12", "*", "Pi", "*", 
         RowBox[{"x", "^", "2"}], "*", 
         RowBox[{"gVal", "[", "x", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"fVal", "'"}], "[", "x", "]"}], "==", 
        RowBox[{
         RowBox[{"fIntegrand", "[", 
          RowBox[{"y", "[", "x", "]"}], "]"}], "*", 
         RowBox[{
          RowBox[{"y", "'"}], "[", "x", "]"}]}]}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"gVal", "'"}], "[", "x", "]"}], "==", 
        RowBox[{
         RowBox[{"gIntegrand", "[", 
          RowBox[{"y", "[", "x", "]"}], "]"}], "*", 
         RowBox[{
          RowBox[{"y", "'"}], "[", "x", "]"}]}]}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Set", " ", "Initial", " ", "Conditions", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"near", " ", "the", " ", "origin", " ", "x"}], "=", "0"}], 
      ")"}]}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
     "We", " ", "use", " ", "a", " ", "small", " ", "epsilon", " ", "offset", 
      " ", "to", " ", "avoid", " ", "the", " ", "numerical", " ", 
      "singularity", " ", "at", " ", "x"}], "=", "0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"epsilon", "=", 
     RowBox[{"10", "^", 
      RowBox[{"-", "8"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"initialConditions", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"y", "[", "epsilon", "]"}], "==", "yc"}], ",", 
       RowBox[{
        RowBox[{"m", "[", "epsilon", "]"}], "==", "0"}], ",", 
       RowBox[{
        RowBox[{"fVal", "[", "epsilon", "]"}], "==", 
        RowBox[{"NIntegrate", "[", 
         RowBox[{
          RowBox[{"fIntegrand", "[", "t", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "0", ",", "yc"}], "}"}]}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"gVal", "[", "epsilon", "]"}], "==", 
        RowBox[{"NIntegrate", "[", 
         RowBox[{
          RowBox[{"gIntegrand", "[", "t", "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "0", ",", "yc"}], "}"}]}], "]"}]}]}], "}"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"5.", " ", "Solve", " ", "using", " ", "NDSolve"}], "*)"}], "\n", 
   
   RowBox[{"(*", 
    RowBox[{
    "We", " ", "use", " ", "\"\<EventLocator\>\"", " ", "to", " ", "stop", " ",
      "integration", " ", "when", " ", "y", 
     RowBox[{"(", "x", ")"}], " ", "hits", " ", "0", " ", 
     RowBox[{"(", 
      RowBox[{"the", " ", "star", " ", "surface"}], ")"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solution", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"Join", "[", 
        RowBox[{"tovEquations", ",", "initialConditions"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"y", ",", "m", ",", "fVal", ",", "gVal"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"x", ",", "epsilon", ",", "10"}], "}"}], ",", 
       RowBox[{"Method", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<EventLocator\>\"", ",", 
          RowBox[{"\"\<Event\>\"", "->", 
           RowBox[{"y", "[", "x", "]"}]}], ",", 
          RowBox[{"\"\<Direction\>\"", "->", 
           RowBox[{"-", "1"}]}]}], "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"6.", " ", "Extract", " ", 
     RowBox[{"Results", ":", 
      RowBox[{
      "Surface", " ", "Radius", " ", "and", " ", "Total", " ", "Mass"}]}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"xSurface", "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"y", "/.", " ", 
         RowBox[{"solution", "[", 
          RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "[", "\"\<Domain\>\"", 
       "]"}], "[", 
      RowBox[{"[", 
       RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"mTotal", "=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"m", "/.", " ", 
        RowBox[{"solution", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "[", "xSurface", "]"}]}], 
    ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<--- TOV Solver Results ---\>\"", "]"}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Dimensionless Radius (R/R0): \>\"", ",", "xSurface"}], 
     "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<Dimensionless Mass (M/mu): \>\"", ",", "mTotal"}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"7.", " ", "Plotting", " ", "the", " ", "Profiles"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"y", "[", "x", "]"}], "/.", " ", "solution"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "epsilon", ",", "xSurface"}], "}"}], ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<Dimensionless Fermi Momentum Profile y(x)\>\""}],
      ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<x (Radius)\>\"", ",", "\"\<y (Momentum)\>\""}], "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", "Blue"}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}]}], "]"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"Evaluate", "[", 
      RowBox[{
       RowBox[{"m", "[", "x", "]"}], "/.", " ", "solution"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", "epsilon", ",", "xSurface"}], "}"}], ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<Cumulative Dimensionless Mass m(x)\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<x (Radius)\>\"", ",", "\"\<m (Mass)\>\""}], "}"}]}], ",", 
     
     RowBox[{"PlotStyle", "->", "Red"}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9814902203686867`*^9, 3.9814902203712893`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"6e058cde-e1bb-4be9-8bae-27e6d40d5365"],

