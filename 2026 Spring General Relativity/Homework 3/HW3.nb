Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"1.", " ", "Physics", " ", "Functions"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", 
     RowBox[{
     "solveMassDensity", ",", "pressureFunc", ",", "densityFunc", ",", 
      "derivP"}], "]"}], ";"}], "\n", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"pressureFunc", "[", "y_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"8", " ", 
          RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"y", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", 
            RowBox[{
             RowBox[{"y", "^", "2"}], "/", "3"}]}], "-", "1"}], ")"}], " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"y", "^", "2"}], "+", "1"}], "]"}]}], "+", 
        RowBox[{"ArcSinh", "[", "y", "]"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"densityFunc", "[", "y_", "]"}], ":=", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"(", 
         RowBox[{"8", " ", 
          RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"y", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"2", " ", 
            RowBox[{"y", "^", "2"}]}], "+", "1"}], ")"}], " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{
           RowBox[{"y", "^", "2"}], "+", "1"}], "]"}]}], "-", 
        RowBox[{"ArcSinh", "[", "y", "]"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"derivP", "[", "y_", "]"}], ":=", 
     RowBox[{
      RowBox[{"y", "^", "4"}], "/", 
      RowBox[{"(", 
       RowBox[{"3", " ", 
        RowBox[{"Pi", "^", "2"}], " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"y", "^", "2"}], "+", "1"}], "]"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"2.", " ", "Refined", " ", "Solver", " ", "Function"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"solveMassDensity", "[", 
      RowBox[{"yc_", "?", "NumericQ"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"sol", ",", 
         RowBox[{"eps", "=", 
          RowBox[{"10", "^", 
           RowBox[{"-", "5"}]}]}], ",", 
         RowBox[{"rMax", "=", "2000"}], ",", "rhoC", ",", "mFinal"}], "}"}], ",", 
       RowBox[{
        RowBox[{"rhoC", "=", 
         RowBox[{"densityFunc", "[", "yc", "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"sol", "=", 
         RowBox[{"NDSolve", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"y", "'"}], "[", "x", "]"}], "==", 
              RowBox[{
               RowBox[{"-", 
                RowBox[{"(", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"densityFunc", "[", 
                    RowBox[{"y", "[", "x", "]"}], "]"}], "+", 
                    RowBox[{"pressureFunc", "[", 
                    RowBox[{"y", "[", "x", "]"}], "]"}]}], ")"}], " ", 
                  RowBox[{"(", 
                   RowBox[{
                    RowBox[{"m", "[", "x", "]"}], "+", 
                    RowBox[{"4", " ", "Pi", " ", 
                    RowBox[{"x", "^", "3"}], " ", 
                    RowBox[{"pressureFunc", "[", 
                    RowBox[{"y", "[", "x", "]"}], "]"}]}]}], ")"}]}], ")"}]}],
                "/", 
               RowBox[{"(", 
                RowBox[{"x", " ", 
                 RowBox[{"(", 
                  RowBox[{"x", "-", 
                   RowBox[{"2", " ", 
                    RowBox[{"m", "[", "x", "]"}]}]}], ")"}], " ", 
                 RowBox[{"derivP", "[", 
                  RowBox[{"y", "[", "x", "]"}], "]"}]}], ")"}]}]}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{"m", "'"}], "[", "x", "]"}], "==", 
              RowBox[{"4", " ", "Pi", " ", 
               RowBox[{"x", "^", "2"}], " ", 
               RowBox[{"densityFunc", "[", 
                RowBox[{"y", "[", "x", "]"}], "]"}]}]}], ",", 
             RowBox[{
              RowBox[{"y", "[", "eps", "]"}], "==", "yc"}], ",", 
             RowBox[{
              RowBox[{"m", "[", "eps", "]"}], "==", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"4", "/", "3"}], ")"}], " ", "Pi", " ", 
               RowBox[{"eps", "^", "3"}], " ", "rhoC"}]}], ",", 
             RowBox[{"WhenEvent", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"y", "[", "x", "]"}], "<", 
                RowBox[{"10", "^", 
                 RowBox[{"-", "7"}]}]}], ",", "\"\<StopIntegration\>\""}], 
              "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"y", ",", "m"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"x", ",", "eps", ",", "rMax"}], "}"}], ",", 
           RowBox[{"(*", 
            RowBox[{"Fixed", " ", "Method", " ", "Syntax"}], "*)"}], 
           RowBox[{"Method", "->", 
            RowBox[{"{", 
             RowBox[{"\"\<StiffnessSwitching\>\"", ",", 
              RowBox[{"Method", "->", 
               RowBox[{"{", 
                
                RowBox[{"\"\<ExplicitRungeKutta\>\"", 
                 ",", "\"\<Automatic\>\""}], "}"}]}]}], "}"}]}], ",", 
           RowBox[{"MaxSteps", "->", "50000"}], ",", 
           RowBox[{"PrecisionGoal", "->", "6"}], ",", 
           RowBox[{"AccuracyGoal", "->", "6"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"(*", 
         RowBox[{
         "Check", " ", "if", " ", "NDSolve", " ", "returned", " ", "a", " ", 
          "valid", " ", "list", " ", "of", " ", "rules"}], "*)"}], 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"MatchQ", "[", 
           RowBox[{"sol", ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"_", "->", "_"}], ")"}], ".."}], "}"}], ".."}], 
             "}"}]}], "]"}], ",", 
          RowBox[{
           RowBox[{"mFinal", "=", 
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"m", "/.", " ", 
                RowBox[{"sol", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], ")"}], 
              "[", "\"\<ValuesOnGrid\>\"", "]"}], "//", "Last"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"{", 
            RowBox[{"rhoC", ",", "mFinal"}], "}"}]}], ",", "Nothing"}], " ", 
         RowBox[{"(*", 
          RowBox[{"Skip", " ", "if", " ", "failed"}], "*)"}], "]"}]}]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"3.", " ", "Data", " ", "Generation"}], "*)"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Using", " ", "a", " ", "smaller", " ", "sample", " ", "size", " ", 
     "first", " ", "to", " ", "verify", " ", "stability"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"yValues", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"10", "^", "v"}], ",", 
       RowBox[{"{", 
        RowBox[{"v", ",", 
         RowBox[{"-", "1.5"}], ",", "1.5", ",", "0.01"}], "}"}]}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"Map", "[", 
      RowBox[{"solveMassDensity", ",", "yValues"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"4.", " ", "Visualization"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"If", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Length", "[", "data", "]"}], ">", "0"}], ",", 
     RowBox[{"ListLogLinearPlot", "[", 
      RowBox[{"data", ",", 
       RowBox[{"Joined", "->", "True"}], ",", 
       RowBox[{"Mesh", "->", "All"}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"GridLines", "->", "Automatic"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Central Density (\[Rho]_c)\>\"", 
          ",", "\"\<Total Mass (M)\>\""}], "}"}]}], ",", 
       RowBox[{
       "PlotLabel", 
        "->", "\"\<Mass-Density Relation (White Dwarf Fermi Gas)\>\""}], ",", 
       
       RowBox[{"PlotStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Blue", ",", "Thick"}], "}"}]}], ",", 
       RowBox[{"ImageSize", "->", "Full"}]}], "]"}], 
     ",", "\"\<Solver failed to produce valid data.\>\""}], 
    "]"}]}]}]], "Input",
