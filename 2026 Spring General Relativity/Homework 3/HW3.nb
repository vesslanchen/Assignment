Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "solveStar", ",", "x", ",", "y", ",", "m", ",", "fP", ",", "fRho", ",", 
     "dfPdy"}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "1.", " ", 
    "\:7269\:7406\:91cf\:8207\:72c0\:614b\:65b9\:7a0b\:5b9a\:7fa9"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fP", "[", "y_", "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"8", " ", 
        RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"y", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{
           RowBox[{"y", "^", "2"}], "/", "3"}]}], "-", "1"}], ")"}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"y", "^", "2"}], "+", "1"}], "]"}]}], "+", 
      RowBox[{"ArcSinh", "[", "y", "]"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fRho", "[", "y_", "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"8", " ", 
        RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"y", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"y", "^", "2"}]}], "+", "1"}], ")"}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"y", "^", "2"}], "+", "1"}], "]"}]}], "-", 
      RowBox[{"ArcSinh", "[", "y", "]"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dfPdy", "[", "y_", "]"}], ":=", 
    RowBox[{
     RowBox[{"y", "^", "4"}], "/", 
     RowBox[{"(", 
      RowBox[{"3", " ", 
       RowBox[{"Pi", "^", "2"}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"y", "^", "2"}], "+", "1"}], "]"}]}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"2.", " ", "\:55ae\:6b21\:6c42\:89e3\:51fd\:6578", " ", 
    RowBox[{"(", "\:589e\:52a0\:7a69\:5b9a\:6027\:8655\:7406", ")"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"solveStar", "[", 
     RowBox[{"yc_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sol", ",", 
        RowBox[{"eps", "=", 
         RowBox[{"10", "^", 
          RowBox[{"-", "5"}]}]}], ",", 
        RowBox[{"rMax", "=", "100"}]}], "}"}], ",", 
      RowBox[{
       RowBox[{"sol", "=", 
        RowBox[{"NDSolve", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"y", "'"}], "[", "x", "]"}], "==", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"fRho", "[", 
                    RowBox[{"y", "[", "x", "]"}], "]"}], "+", 
                   RowBox[{"fP", "[", 
                    RowBox[{"y", "[", "x", "]"}], "]"}]}], ")"}], " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"m", "[", "x", "]"}], "+", 
                   RowBox[{"4", " ", "Pi", " ", 
                    RowBox[{"x", "^", "3"}], " ", 
                    RowBox[{"fP", "[", 
                    RowBox[{"y", "[", "x", "]"}], "]"}]}]}], ")"}]}], ")"}]}],
               "/", 
              RowBox[{"(", 
               RowBox[{"x", " ", 
                RowBox[{"(", 
                 RowBox[{"x", "-", 
                  RowBox[{"2", " ", 
                   RowBox[{"m", "[", "x", "]"}]}]}], ")"}], " ", 
                RowBox[{"dfPdy", "[", 
                 RowBox[{"y", "[", "x", "]"}], "]"}]}], ")"}]}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"m", "'"}], "[", "x", "]"}], "==", 
             RowBox[{"4", " ", "Pi", " ", 
              RowBox[{"x", "^", "2"}], " ", 
              RowBox[{"fRho", "[", 
               RowBox[{"y", "[", "x", "]"}], "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"y", "[", "eps", "]"}], "==", "yc"}], ",", 
            RowBox[{
             RowBox[{"m", "[", "eps", "]"}], "==", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"4", "/", "3"}], ")"}], " ", "Pi", " ", 
              RowBox[{"eps", "^", "3"}], " ", 
              RowBox[{"fRho", "[", "yc", "]"}]}]}], ",", 
            RowBox[{"WhenEvent", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"y", "[", "x", "]"}], "<", 
               RowBox[{"10", "^", 
                RowBox[{"-", "6"}]}]}], ",", "\"\<StopIntegration\>\""}], 
             "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"y", ",", "m"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "eps", ",", "rMax"}], "}"}], ",", 
          RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}], ",", 
          RowBox[{"PrecisionGoal", "->", "10"}], ",", 
          RowBox[{"AccuracyGoal", "->", "10"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "sol", "]"}], ">", "0"}], ",", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"xf", ",", "mf", ",", "yfunc", ",", "mfunc"}], "}"}], ",", 
           RowBox[{
            RowBox[{"yfunc", "=", 
             RowBox[{"y", "/.", " ", 
              RowBox[{"sol", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"mfunc", "=", 
             RowBox[{"m", "/.", " ", 
              RowBox[{"sol", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"xf", "=", 
             RowBox[{
              RowBox[{"yfunc", "[", "\"\<Domain\>\"", "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"mf", "=", 
             RowBox[{"mfunc", "[", "xf", "]"}]}], ";", "\[IndentingNewLine]", 
            
            RowBox[{"{", 
             RowBox[{"xf", ",", "mf"}], "}"}]}]}], "]"}], ",", "Nothing"}], 
        "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{
   "3.", " ", 
    "\:589e\:52a0\:63a1\:6a23\:5bc6\:5ea6\:4ee5\:7372\:5f97\:5e73\:6ed1\:66f2\
\:7dda"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<\:6b63\:5728\:8a08\:7b97\:9ad8\:7cbe\:5ea6\:6578\:64da\
\:9ede...\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"ycList", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"yVal", ",", 
     RowBox[{"{", 
      RowBox[{"yVal", ",", "0.05", ",", "5.0", ",", "0.01"}], "}"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"results", "=", 
    RowBox[{"ParallelTable", "[", 
     RowBox[{
      RowBox[{"solveStar", "[", "yv", "]"}], ",", 
