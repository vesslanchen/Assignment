Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "solveStar", ",", "x", ",", "y", ",", "m", ",", "fP", ",", "fRho", ",", 
     "dfPdy"}], "]"}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"1.", " ", "\:7269\:7406\:91cf\:5b9a\:7fa9"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fP", "[", "y_", "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"8", " ", 
        RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"y", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{
           RowBox[{"y", "^", "2"}], "/", "3"}]}], "-", "1"}], ")"}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"y", "^", "2"}], "+", "1"}], "]"}]}], "+", 
      RowBox[{"ArcSinh", "[", "y", "]"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"fRho", "[", "y_", "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "/", 
      RowBox[{"(", 
       RowBox[{"8", " ", 
        RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"y", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"y", "^", "2"}]}], "+", "1"}], ")"}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"y", "^", "2"}], "+", "1"}], "]"}]}], "-", 
      RowBox[{"ArcSinh", "[", "y", "]"}]}], ")"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"dfPdy", "[", "y_", "]"}], ":=", 
    RowBox[{
     RowBox[{"y", "^", "4"}], "/", 
     RowBox[{"(", 
      RowBox[{"3", " ", 
       RowBox[{"Pi", "^", "2"}], " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"y", "^", "2"}], "+", "1"}], "]"}]}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"2.", " ", "\:55ae\:6b21\:6c42\:89e3\:51fd\:6578"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"solveStar", "[", 
     RowBox[{"yc_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sol", ",", 
        RowBox[{"eps", "=", 
         RowBox[{"10", "^", 
          RowBox[{"-", "6"}]}]}], ",", 
        RowBox[{"rMax", "=", "100"}]}], "}"}], ",", 
      RowBox[{
       RowBox[{"sol", "=", 
        RowBox[{"NDSolve", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"y", "'"}], "[", "x", "]"}], "==", 
             RowBox[{
              RowBox[{"-", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"fRho", "[", 
                    RowBox[{"y", "[", "x", "]"}], "]"}], "+", 
                   RowBox[{"fP", "[", 
                    RowBox[{"y", "[", "x", "]"}], "]"}]}], ")"}], " ", 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"m", "[", "x", "]"}], "+", 
                   RowBox[{"4", " ", "Pi", " ", 
                    RowBox[{"x", "^", "3"}], " ", 
                    RowBox[{"fP", "[", 
                    RowBox[{"y", "[", "x", "]"}], "]"}]}]}], ")"}]}], ")"}]}],
               "/", 
              RowBox[{"(", 
               RowBox[{"x", " ", 
                RowBox[{"(", 
                 RowBox[{"x", "-", 
                  RowBox[{"2", " ", 
                   RowBox[{"m", "[", "x", "]"}]}]}], ")"}], " ", 
                RowBox[{"dfPdy", "[", 
                 RowBox[{"y", "[", "x", "]"}], "]"}]}], ")"}]}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"m", "'"}], "[", "x", "]"}], "==", 
             RowBox[{"4", " ", "Pi", " ", 
              RowBox[{"x", "^", "2"}], " ", 
              RowBox[{"fRho", "[", 
               RowBox[{"y", "[", "x", "]"}], "]"}]}]}], ",", 
            RowBox[{
             RowBox[{"y", "[", "eps", "]"}], "==", "yc"}], ",", 
            RowBox[{
             RowBox[{"m", "[", "eps", "]"}], "==", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"4", "/", "3"}], ")"}], " ", "Pi", " ", 
              RowBox[{"eps", "^", "3"}], " ", 
              RowBox[{"fRho", "[", "yc", "]"}]}]}], ",", 
            RowBox[{"(*", 
             RowBox[{
             "\:7576\:52d5\:91cf\:964d\:5230\:63a5\:8fd1", " ", "0", " ", 
              "\:6642\:505c\:6b62\:8a08\:7b97"}], "*)"}], 
            RowBox[{"WhenEvent", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"y", "[", "x", "]"}], "<", 
               RowBox[{"10", "^", 
                RowBox[{"-", "5"}]}]}], ",", "\"\<StopIntegration\>\""}], 
             "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"y", ",", "m"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"x", ",", "eps", ",", "rMax"}], "}"}], ",", 
          RowBox[{"Method", "->", "\"\<StiffnessSwitching\>\""}], ",", 
          RowBox[{"PrecisionGoal", "->", "8"}], ",", 
          RowBox[{"AccuracyGoal", "->", "8"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Length", "[", "sol", "]"}], ">", "0"}], ",", 
         RowBox[{"Module", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"xf", ",", "mf"}], "}"}], ",", 
           RowBox[{
            RowBox[{"xf", "=", 
             RowBox[{
              RowBox[{
               RowBox[{"(", 
                RowBox[{"y", "/.", " ", 
                 RowBox[{"sol", "[", 
                  RowBox[{"[", "1", "]"}], "]"}]}], ")"}], 
               "[", "\"\<Domain\>\"", "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"1", ",", "2"}], "]"}], "]"}]}], ";", 
            "\[IndentingNewLine]", 
            RowBox[{"mf", "=", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"m", "/.", " ", 
                RowBox[{"sol", "[", 
                 RowBox[{"[", "1", "]"}], "]"}]}], ")"}], "[", "xf", "]"}]}], 
            ";", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{"xf", ",", "mf"}], "}"}]}]}], "]"}], ",", "Nothing"}], 
        "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"3.", " ", "\:6279\:91cf\:8a08\:7b97\:6578\:64da"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", "\"\<Calculating M-R Data Points...\>\"", "]"}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"ycList", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"yVal", ",", 
     RowBox[{"{", 
      RowBox[{"yVal", ",", "0.01", ",", "1.5", ",", "0.001"}], "}"}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"results", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Print", "[", 
        RowBox[{"\"\<Computing yc = \>\"", ",", "yv"}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"solveStar", "[", "yv", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"yv", ",", "ycList"}], "}"}]}], "]"}]}], ";"}], "\n", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"4.", " ", "\:7e6a\:88fd", " ", "M"}], "-", 
    RowBox[{"R", " ", "\:5716"}]}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mrPoints", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"results", ",", "ListQ"}], "]"}]}], ";"}], "\n", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Length", "[", "mrPoints", "]"}], ">", "0"}], ",", 
   RowBox[{"ListLinePlot", "[", 
    RowBox[{"mrPoints", ",", 
     RowBox[{"Frame", "->", "True"}], ",", 
     RowBox[{"FrameLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Radius (R)\>\"", ",", "\"\<Mass (M)\>\""}], "}"}]}], ",", 
     
     RowBox[{"PlotMarkers", "->", "Automatic"}], ",", 
     RowBox[{"PlotLabel", "->", "\"\<White Dwarf Mass-Radius Curve\>\""}], ",", 
     RowBox[{"PlotStyle", "->", "Blue"}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}]}], "]"}], ",", 
   RowBox[{"Print", "[", "\"\<No data points were generated.\>\"", "]"}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.981490708356241*^9, 3.9814907175451527`*^9}, {
  3.981490750341275*^9, 3.981490780206212*^9}},
