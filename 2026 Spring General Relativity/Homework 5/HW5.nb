Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"m", "=", "1"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Mpl", "=", 
   RowBox[{"1.22", "*", 
    RowBox[{"10", "^", "19"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"gStar", "=", "10"}], ";"}], " ", "\n", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"nFull", "[", 
     RowBox[{"T_", "?", "NumericQ"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"2", "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", 
         RowBox[{"Pi", "^", "2"}]}], ")"}]}], ")"}], "*", 
     RowBox[{"NIntegrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"p", "^", "2"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"Sqrt", "[", 
             RowBox[{
              RowBox[{"p", "^", "2"}], "+", 
              RowBox[{"m", "^", "2"}]}], "]"}], "/", "T"}], "]"}], "+", "1"}],
          ")"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"p", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"gammaFull", "[", 
    RowBox[{"T_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"T", "^", "2"}], "/", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"T", "^", "2"}], "+", 
         RowBox[{"m", "^", "2"}]}], ")"}], "^", "2"}]}], ")"}], "*", 
    RowBox[{"nFull", "[", "T", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"hubble", "[", "T_", "]"}], ":=", 
    RowBox[{"1.66", "*", 
     RowBox[{"Sqrt", "[", "gStar", "]"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"T", "^", "2"}], "/", "Mpl"}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\n", 
 RowBox[{"LogLogPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"gammaFull", "[", "T", "]"}], ",", 
     RowBox[{"hubble", "[", "T", "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"T", ",", "0.01", ",", "10"}], "}"}], ",", 
   RowBox[{"PlotRange", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"10", "^", 
       RowBox[{"-", "25"}]}], ",", "10"}], "}"}]}], ",", 
   RowBox[{"GridLines", "->", "Automatic"}], ",", 
   RowBox[{"PlotLabels", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<Gamma (Full Integral)\>\"", ",", "\"\<H (T)\>\""}], "}"}]}],
    ",", 
   RowBox[{"FrameLabel", "->", 
    RowBox[{"{", 
     RowBox[{"\"\<T (GeV)\>\"", ",", "\"\<Rate (GeV)\>\""}], "}"}]}]}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"FindRoot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"gammaFull", "[", "T", "]"}], "==", 
    RowBox[{"hubble", "[", "T", "]"}]}], ",", 
   RowBox[{"{", 
    RowBox[{"T", ",", "0.03"}], "}"}]}], 
  "]"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9840565368860617`*^9, 3.984056592827237*^9}, {
